# Get a free project ID at https://cloud.reown.com (formerly WalletConnect Cloud)
# Required only for the WalletConnect (QR code / mobile wallet) connector.
# MetaMask and Rabby work without this — they're auto-detected via EIP-6963.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Escrow / treasury / oracle (server-side only — never expose these client-side) ---

# From Circle Console (console.circle.com -> Developer -> API & Client Keys)
CIRCLE_API_KEY=

# Generated + registered once via scripts/setup-circle-wallets.mjs — this is
# the master key for every wallet under this entity. Never commit it.
CIRCLE_ENTITY_SECRET=

# All from scripts/setup-circle-wallets.mjs's output:
CIRCLE_WALLET_SET_ID=
TREASURY_WALLET_ID=
TREASURY_ADDRESS=
ORACLE_WALLET_ID=
ORACLE_ADDRESS=

# Long random string protecting /api/resolve-challenge from being called by
# anyone but you. Generate with: openssl rand -hex 32
API_ADMIN_SECRET=
